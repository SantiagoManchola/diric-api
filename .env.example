# ==============================================
# DIRIC API - Variables de Entorno
# ==============================================

# Base de datos (Supabase PostgreSQL)
# Obtén esta URL desde: https://supabase.com → tu proyecto → Settings → Database → Connection string (URI)
DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.zlssoycxxeltbuaiskrg.supabase.co:5432/postgres"

# URL directa (para migraciones Prisma)
DIRECT_URL="postgresql://postgres.[TU-PROYECTO]:[TU-PASSWORD]@aws-0-[REGION].pooler.supabase.com:5432/postgres"

# JWT
JWT_SECRET="cambia-esto-por-un-secreto-seguro-de-al-menos-32-caracteres"
JWT_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS - URLs del frontend separadas por coma
CORS_ORIGIN="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="tu-google-client-id.apps.googleusercontent.com"

# ==============================================
# Cloudflare R2 (almacenamiento de imágenes y PDFs)
# Dashboard: https://dash.cloudflare.com → R2 → tu bucket → Settings
# ==============================================

# ID de tu cuenta Cloudflare (Account ID en el dashboard principal)
R2_ACCOUNT_ID="tu-account-id-cloudflare"

# Credenciales del token de API R2
# Crear en: R2 → Manage R2 API Tokens → Create API Token (Object Read & Write)
R2_ACCESS_KEY_ID="tu-r2-access-key-id"
R2_SECRET_ACCESS_KEY="tu-r2-secret-access-key"

# Nombre del bucket R2
R2_BUCKET_NAME="diric-storage"

# URL pública del bucket (configura un Custom Domain o usa el dominio r2.dev en el bucket)
# Ejemplo con dominio propio: https://storage.tudominio.com
# Ejemplo con r2.dev:         https://pub-xxxxxxxxxxxx.r2.dev
R2_PUBLIC_URL="https://tu-dominio-publico.r2.dev"
